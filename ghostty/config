# Ghostty config — light theme, JetBrains Mono ExtraLight
# layout/spacing inspired by ~/.dotfiles/hyper/.hyper.js

# --- font ---
font-family = JetBrains Mono
font-style = ExtraLight
font-style-bold = Bold
font-size = 11.7
adjust-cell-height = 20%
font-feature = -liga
font-feature = -calt

# --- theme ---
# Try also: "Tomorrow", "GitHub Light Default", "Atom One Light", "Ayu Light"
theme = Catppuccin Latte

# match nvim colors/vs_light.vim and vs_dark.vim Normal hi-group
background = F2F2F2
foreground = 000000

# keep the signature magenta cursor across themes
cursor-color = f81ce5
cursor-text = ffffff
cursor-style = block
cursor-style-blink = false
selection-background = f81ce5
selection-foreground = ffffff

# --- window / layout ---
# Hyper had `padding: '8px 15%'` — Ghostty only takes pixels.
# Tune `window-padding-x` to taste; ~240 feels centered on a 13–16" mac.
window-padding-x = 400
window-padding-y = 12
window-padding-balance = true
window-save-state = always
# tabs integrated into the titlebar — most compact tab-friendly option
macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
window-show-tab-bar = never

# --- behavior ---
bold-is-bright = false
copy-on-select = false
mouse-hide-while-typing = true
confirm-close-surface = false
shell-integration = detect
