[user]
	name = Isai Gordeev
	email = isaigordeev@gmail.com
	signingkey = F4F078EB57EA2C67C23E0F5CB94FFCADE32BE35A
[core]
	autocrlf = input
	pager = delta
[commit]
	gpgsign = true
[gpg]
	program = /usr/local/bin/gpg
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[rebase]
	gpgSign = true
[alias]
	lg = log --all --oneline --graph --decorate
[http]
	postBuffer = 524288000
[interactive]
	diffFilter = delta --color-only
[delta]
	line-numbers = true
	syntax-theme = Dracula
