[user]
	name = Isai Gordeev
	email = isaigordeev@gmail.com
	signingkey = E32BE35A
[commit]
	gpgsign = true
[alias]
	lg = log --all --oneline --graph --decorate
	lgc = log --oneline --graph --decorate HEAD @{u}
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	light = true
	syntax-theme = ansi
	; Always stream to stdout, never open a pager (any length). Delta still
	; colorizes + adds metadata; output lands in the terminal/tmux scrollback.
	paging = never
	; jj-like minimalism: drop the box/rule "boarding lines" but keep the
	; +/- background highlight (minus-/plus-style left at defaults).
	hunk-header-style = omit
	file-decoration-style = none
	file-style = blue
	; line-number gutter without the dotted/solid vertical bars -- just the
	; numbers and a ":" separator, like jj.
	line-numbers-left-format = "{nm:>4} "
	line-numbers-right-format = "{np:>4} : "
	line-numbers-left-style = blue
	line-numbers-right-style = blue
	line-numbers-zero-style = "#cccccc"
[merge]
	conflictStyle = diff3
[diff]
	colorMoved = default
[pager]
	diff = true
[sendemail]
	smtpServer = smtp.gmail.com
	smtpServerPort = 587
	smtpEncryption = tls
	smtpUser = isai.gordeev.2022@polytechnique.org
